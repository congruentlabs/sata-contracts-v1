{
  "name": "sata-contracts-v1",
  "version": "0.0.3",
  "description": "Solidity Smart Contracts for the Signata Project",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:node": "hardhat node",
    "test:local": "hardhat run --network localhost scripts/deploy_identity_v1.js",
    "deploy:sepolia": "hardhat run --network sepolia scripts/deploy_identity_v1.js",
    "deploy:mainnet": "hardhat run --network mainnet scripts/deploy_identity_v1.js",
    "deploy:bsc": "hardhat run --network bsc scripts/deploy_identity_v1.js",
    "analyze": "slither .",
    "lint": "solhint \"contracts/**/*.sol\""
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/congruentlabs/sata-contracts-v1.git"
  },
  "author": "Congruent Labs Pty Ltd",
  "license": "MIT",
  "homepage": "https://github.com/congruentlabs/sata-contracts-v1#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/hardhat-upgrades": "^3.6.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.17",
    "solhint": "^5.0.5"
  }
}
